---
import Base from "../../layouts/Base.astro";
---

<Base
  title="Thanks — W74"
  description="Your message has been sent to W74."
  noindex
>
  <div class="mx-auto max-w-3xl px-4 py-24 sm:px-6 md:py-36">
    <h1 class="font-display text-4xl font-bold tracking-tight sm:text-5xl">
      Thanks — we'll reply within one business day.
    </h1>
    <p class="mt-6 text-lg text-muted">
      In the meantime, take a look at{" "}
      <a href="/projects" class="font-medium text-pine hover:text-pine-deep"
        >our selected work</a
      >{" "}or try the{" "}
      <a href="/" class="font-medium text-pine hover:text-pine-deep"
        >demo apps</a
      >.
    </p>
    <a
      href="/"
      class="mt-10 inline-block rounded-md bg-pine px-6 py-3 font-medium text-white transition-colors hover:bg-pine-deep"
    >
      Back to home
    </a>
  </div>
</Base>
