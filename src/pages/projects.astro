---
import Base from "../layouts/Base.astro";
import { pillars } from "../data/pillars";

type CaseStudy = {
  client: string;
  /** Keep the Accenture dagger (†) disclosure attached wherever it appears. */
  dagger?: boolean;
  body: string;
  demos?: { label: string; url: string }[];
};

const sections: Record<string, { cases: CaseStudy[]; pdf?: { label: string; href: string } }> = {
  validate: {
    cases: [
      {
        client: "Bedrock Energy (Series A)",
        body: "Designed and implemented the performance validation framework that quantifies the energy, cost, and GHG savings of Bedrock's ground-source heat-pump technology — and continue to provide ongoing performance monitoring.",
      },
      {
        client: "Leading California health system",
        body: "ML-based IPMVP Option C M&V deployed across a $16B+ health system's 50+ properties.",
      },
    ],
    pdf: { label: "View a sample M&V report (PDF) →", href: "/assets/sample-mv-report.pdf" },
  },
  reduce: {
    cases: [
      {
        client: "Accenture Smart Buildings",
        dagger: true,
        body: "Ongoing fault detection & HVAC optimization across 150+ properties in a global smart-buildings portfolio.",
      },
      {
        client: "Jane Energy (Seed)",
        body: "Virtual energy audits across multifamily, commercial, and industrial portfolios — including several REIT owners — identifying savings of 25–30% of utility spend per property from utility bills, permits, and weather data, delivered as a prioritized quick-wins-vs-capex roadmap.",
      },
    ],
  },
  build: {
    cases: [
      {
        client: "Jane Energy (Seed)",
        body: "Accelerated the design of Jane's enterprise app and customer-facing ECM summaries.",
      },
      {
        client: "W74 Apps",
        body: "Built our own forecasting and M&V applications. Try them:",
        demos: [
          { label: "Energy Forecast App", url: "https://w74-forecast.streamlit.app/" },
          { label: "M&V App", url: "https://w74-energy.streamlit.app/" },
        ],
      },
    ],
    pdf: { label: "View a sample ECM summary (PDF) →", href: "/assets/sample-ecm-summary.pdf" },
  },
  grow: {
    cases: [
      {
        client: "Jane Energy (Seed)",
        body: "Partnered with Jane to close their seed round — strategy, pitch deck, and investor introductions — then provided hands-on delivery for their first customer pilots. We continue making introductions to prospective enterprise customers.",
      },
      {
        client: "Stealth HVAC analytics startup (Pre-seed)",
        body: "Guided the raise, sharpened the pitch deck and product strategy, and delivered initial fault-detection recommendations.",
      },
    ],
  },
};
---

<Base
  title="Projects & Case Studies — W74"
  description="Selected W74 engagements across performance validation, energy & OpEx reduction, product development, and growth."
>
  <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6 md:py-28">
    <h1 class="font-display text-4xl font-bold tracking-tight sm:text-5xl">
      Selected work
    </h1>
    <p class="mt-4 text-lg text-muted">
      Four kinds of problems we solve, and the engagements behind them.
    </p>

    <div class="mt-16 space-y-20">
      {
        pillars.map((pillar) => {
          const section = sections[pillar.id];
          return (
            <section
              id={pillar.id}
              aria-labelledby={`${pillar.id}-heading`}
              class="scroll-mt-24 border-t border-line pt-10"
            >
              <p class="font-mono text-sm text-pine">{pillar.number}</p>
              <h2
                id={`${pillar.id}-heading`}
                class="mt-3 font-display text-3xl font-bold tracking-tight"
              >
                {pillar.title}
              </h2>
              <p class="mt-4 font-mono text-xs leading-relaxed text-muted">
                {pillar.chips.join(" · ")}
              </p>
              <div class="mt-8 grid gap-6 md:grid-cols-2">
                {section.cases.map((cs) => (
                  <article class="rounded-lg border border-line bg-mist/50 p-6">
                    <h3 class="font-display text-lg font-bold tracking-tight">
                      {cs.client}
                      {cs.dagger && (
                        <a
                          href="#accenture-note"
                          aria-label="See disclosure note about Accenture work"
                          class="text-muted underline decoration-dotted underline-offset-2"
                        >
                          †
                        </a>
                      )}
                    </h3>
                    <p class="mt-3 text-muted">{cs.body}</p>
                    {cs.demos && (
                      <ul class="mt-4 flex flex-wrap gap-x-6 gap-y-2">
                        {cs.demos.map((demo) => (
                          <li>
                            <a
                              href={demo.url}
                              target="_blank"
                              rel="noopener noreferrer"
                              class="font-medium text-pine hover:text-pine-deep"
                            >
                              {demo.label} →
                            </a>
                          </li>
                        ))}
                      </ul>
                    )}
                  </article>
                ))}
              </div>
              {section.pdf && (
                <a
                  href={section.pdf.href}
                  class="mt-6 inline-block font-medium text-pine hover:text-pine-deep"
                >
                  {section.pdf.label}
                </a>
              )}
            </section>
          );
        })
      }
    </div>

    <div id="accenture-note" class="mt-20 border-t border-line pt-8">
      <p class="font-mono text-xs text-muted">
        † Work led by W74 team members at Accenture, prior to W74.
      </p>
      <p class="mt-2 font-mono text-xs text-muted">
        References &amp; introductions available on request.
      </p>
    </div>
  </div>
</Base>
