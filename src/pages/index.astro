---
import Base from "../layouts/Base.astro";
import LoadCurve from "../components/LoadCurve.astro";
import { pillars } from "../data/pillars";

const stats = [
  { value: "$17M+", label: "Energy savings delivered" },
  { value: "200+", label: "Properties analyzed & monitored" },
  { value: "$8M+", label: "Revenue growth driven" },
  { value: "$150M+", label: "Venture financing supported" },
];

/* TODO: confirm the two demo URLs map to the right cards before launch */
const demos = [
  {
    name: "Energy Forecast App",
    description: "Interactive demo of W74's ML load forecasting.",
    url: "https://w74-forecast.streamlit.app/",
    /* TODO: replace placeholder with a real Energy Forecast App screenshot */
    image: "/assets/demo-forecast.svg",
    alt: "Screenshot of the W74 Energy Forecast App (placeholder)",
  },
  {
    name: "M&V App",
    description: "Interactive demo of W74's measurement & verification workflow.",
    url: "https://w74-energy.streamlit.app/",
    /* TODO: replace placeholder with a real M&V App screenshot */
    image: "/assets/demo-mv.svg",
    alt: "Screenshot of the W74 M&V App (placeholder)",
  },
];
---

<Base
  title="W74 — Product & Technology for Climate and Energy Companies"
  description="W74 partners with climate and energy companies to validate performance, reduce energy and OpEx, build better products, and accelerate growth — through fixed-scope projects or embedded fractional support."
>
  <!-- 1. Hero -->
  <section class="relative overflow-hidden border-b border-line">
    <LoadCurve
      class="pointer-events-none absolute inset-x-0 bottom-0 hidden h-full w-full opacity-70 md:block"
    />
    <div class="relative mx-auto max-w-6xl px-4 py-24 sm:px-6 md:py-36">
      <h1
        class="max-w-3xl font-display text-4xl font-bold tracking-tight sm:text-6xl"
      >
        Accelerate your climate work
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-muted">
        W74 partners with climate &amp; energy companies to validate
        performance, reduce energy and OpEx, build better products, and
        accelerate growth — as fixed-scope projects or embedded fractional
        support.
      </p>
      <div class="mt-10 flex flex-wrap items-center gap-4">
        <a
          href="/request"
          class="rounded-md bg-pine px-6 py-3 font-medium text-white transition-colors hover:bg-pine-deep"
        >
          Book an intro call
        </a>
        <a href="/projects" class="font-medium text-pine hover:text-pine-deep">
          See our work →
        </a>
      </div>
    </div>
  </section>

  <!-- 2. Metrics bar -->
  <section aria-label="Results" class="border-b border-line bg-mist">
    <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
      <dl class="grid grid-cols-2 gap-x-6 gap-y-10 md:grid-cols-4">
        {
          stats.map((stat) => (
            <div>
              <dd class="font-display text-4xl font-bold tracking-tight text-ink sm:text-5xl">
                {stat.value}
              </dd>
              <dt class="mt-2 font-mono text-xs tracking-wider text-muted uppercase">
                {stat.label}
              </dt>
            </div>
          ))
        }
      </dl>
      <p class="mt-8 font-mono text-xs text-muted">
        Cumulative figures across W74 client engagements and W74 team-led work.
      </p>
    </div>
  </section>

  <!-- 3. What we do — four pillars -->
  <section class="mx-auto max-w-6xl px-4 py-20 sm:px-6 md:py-28">
    <h2 class="font-display text-3xl font-bold tracking-tight sm:text-4xl">
      What we do
    </h2>
    <div class="mt-12 grid gap-x-12 gap-y-14 md:grid-cols-2">
      {
        pillars.map((pillar) => (
          <article class="border-t border-line pt-6">
            <p class="font-mono text-sm text-pine">{pillar.number}</p>
            <h3 class="mt-3 font-display text-2xl font-bold tracking-tight">
              {pillar.title}
            </h3>
            <p class="mt-3 text-muted">{pillar.blurb}</p>
            <ul class="mt-5 flex flex-wrap gap-2" aria-label="Capabilities">
              {pillar.chips.map((chip) => (
                <li class="rounded-full border border-line px-3 py-1 font-mono text-xs text-muted">
                  {chip}
                </li>
              ))}
            </ul>
            <a
              href={`/projects#${pillar.id}`}
              class="mt-5 inline-block font-medium text-pine hover:text-pine-deep"
            >
              See the work →
            </a>
          </article>
        ))
      }
    </div>
  </section>

  <!-- 4. Try what we build -->
  <section class="border-y border-line bg-mist">
    <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6 md:py-28">
      <h2 class="font-display text-3xl font-bold tracking-tight sm:text-4xl">
        Try what we build
      </h2>
      <p class="mt-3 text-lg text-muted">Working demos, not slideware.</p>
      <div class="mt-12 grid gap-8 md:grid-cols-2">
        {
          demos.map((demo) => (
            <article class="flex flex-col overflow-hidden rounded-lg border border-line bg-paper">
              <img
                src={demo.image}
                alt={demo.alt}
                width="800"
                height="450"
                loading="lazy"
                class="aspect-video w-full border-b border-line object-cover"
              />
              <div class="flex flex-1 flex-col p-6">
                <h3 class="font-display text-xl font-bold tracking-tight">
                  {demo.name}
                </h3>
                <p class="mt-2 flex-1 text-muted">{demo.description}</p>
                <a
                  href={demo.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-5 inline-block self-start rounded-md border border-pine px-5 py-2.5 font-medium text-pine transition-colors hover:bg-pine hover:text-white"
                >
                  Launch demo →
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 5. How we work -->
  <section class="mx-auto max-w-6xl px-4 py-20 sm:px-6 md:py-28">
    <h2 class="font-display text-3xl font-bold tracking-tight sm:text-4xl">
      How we work
    </h2>
    <p class="mt-3 text-lg text-muted">We take on work in two shapes.</p>
    <div class="mt-12 grid gap-x-12 gap-y-10 md:grid-cols-2">
      <article class="border-t border-line pt-6">
        <h3 class="font-display text-xl font-bold tracking-tight">
          Fixed-scope projects
        </h3>
        <p class="mt-3 text-muted">
          You bring a defined problem; we deliver a defined outcome — scoped,
          priced, and run independently. That's how we built Bedrock Energy's
          performance validation framework, and why they've kept us on for
          ongoing monitoring.
        </p>
      </article>
      <article class="border-t border-line pt-6">
        <h3 class="font-display text-xl font-bold tracking-tight">
          Embedded fractional support
        </h3>
        <p class="mt-3 text-muted">
          We join your team as fractional product and engineering leadership,
          and the work moves with your priorities. At Jane Energy, that's meant
          everything from training and building ML models to identifying energy
          conservation measures (ECMs) for their customers as part of pilot
          delivery.
        </p>
      </article>
    </div>
    {/* TODO: confirm timing promises (couple of weeks / weekly cadence) before launch */}
    <p class="mt-12 max-w-3xl text-muted">
      Both start the same way: a conversation with your team, a review of your
      docs and data, and a scoped proposal — usually within a couple of weeks.
      From kickoff, you get a standing weekly cadence and direct access to the
      people doing the work.
    </p>
  </section>

  <!-- 6. Closing CTA band -->
  <section class="border-t border-line bg-ink">
    <div
      class="mx-auto flex max-w-6xl flex-col items-start gap-6 px-4 py-16 sm:px-6 md:flex-row md:items-center md:justify-between"
    >
      <h2 class="font-display text-3xl font-bold tracking-tight text-white">
        Ready to get started?
      </h2>
      <div class="flex flex-wrap items-center gap-6">
        <a
          href="/request"
          class="rounded-md bg-pine px-6 py-3 font-medium text-white transition-colors hover:bg-pine-deep"
        >
          Book an intro call
        </a>
        <a href="mailto:info@w74.io" class="text-lg text-mist hover:text-white">
          info@w74.io
        </a>
      </div>
    </div>
  </section>
</Base>
