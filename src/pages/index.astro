---
import Base from "../layouts/Base.astro";
import LoadCurve from "../components/LoadCurve.astro";
import { pillars } from "../data/pillars";
import { team } from "../data/team";

/* Stat colors match the W74 overview doc's metrics bar */
const stats = [
  { value: "$17M+", label: "Energy savings delivered", color: "text-pine" },
  { value: "200+", label: "Properties analyzed & monitored", color: "text-ink" },
  { value: "$8M+", label: "Revenue growth driven", color: "text-amber" },
  { value: "$150M+", label: "Venture financing supported", color: "text-indigo" },
];

const demos = [
  {
    name: "Energy Forecast App",
    description: "Interactive demo of W74's ML load forecasting.",
    url: "https://w74-forecast.streamlit.app/",
    image: "/assets/demo-forecast.webp",
    alt: "The W74 Energy Forecast App showing a quarterly forward forecast with predicted consumption, estimated spend, and emissions",
  },
  {
    name: "M&V App",
    description: "Interactive demo of W74's measurement & verification workflow.",
    url: "https://w74-energy.streamlit.app/",
    image: "/assets/demo-mv.webp",
    alt: "The W74 M&V App showing IPMVP Option C retrofit impact: annualized savings, energy reduction, and predicted-vs-actual consumption",
  },
];
---

<Base
  title="W74 — Product & Technology for Climate and Energy Companies"
  description="W74 partners with climate and energy companies to validate performance, reduce energy and OpEx, build better products, and accelerate growth — through fixed-scope projects or embedded fractional support."
>
  <!-- 1. Hero (load-curve band sits between the sub text and the CTA row) -->
  <section class="border-b border-line">
    <div class="mx-auto max-w-6xl px-4 pt-12 pb-16 sm:px-6 md:pt-16 md:pb-0">
      <h1 class="font-display text-4xl font-bold tracking-tight sm:text-6xl">
        Accelerate your climate work
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-muted">
        W74 partners with climate &amp; energy companies to validate
        performance, reduce energy and OpEx, build better products, and
        accelerate growth.
      </p>
    </div>
    {/* Remove `interactive` to fall back to the static chart */}
    <LoadCurve
      interactive
      class="mx-auto hidden w-full max-w-[1600px] md:mt-2 md:mb-8 md:block"
    />
  </section>

  <!-- 2. Metrics bar -->
  <section aria-label="Results" class="border-b border-line bg-mist">
    <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
      <dl class="grid grid-cols-2 gap-x-6 gap-y-10 md:grid-cols-4">
        {
          stats.map((stat, i) => (
            <div
              class="reveal flex flex-col-reverse"
              style={`transition-delay: ${i * 130}ms`}
            >
              <dt class="mt-2 font-mono text-xs tracking-wider text-muted uppercase">
                {stat.label}
              </dt>
              <dd
                data-countup
                class:list={[
                  "font-display text-4xl font-bold tracking-tight sm:text-5xl",
                  stat.color,
                ]}
              >
                {stat.value}
              </dd>
            </div>
          ))
        }
      </dl>
      <p class="mt-8 font-mono text-xs text-muted">
        Cumulative figures across W74 client engagements and W74 team-led work.
      </p>
    </div>
  </section>

  <!-- 3. What we do — four pillars with case studies (W74-overview format) -->
  <section id="work" class="scroll-mt-24">
    <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6 md:py-28">
      <p class="font-mono text-xs font-medium tracking-widest text-pine-deep uppercase">
        What we do
      </p>
      <h2 class="mt-3 font-display text-4xl font-bold tracking-tight sm:text-5xl">
        W74 Focus Areas
      </h2>
      <div class="mt-14 space-y-16">
        {
          pillars.map((pillar) => (
            <article
              id={pillar.id}
              class="reveal grid scroll-mt-24 items-start gap-8 border-t border-line pt-10 md:grid-cols-[2fr_3fr] md:gap-12"
            >
              <img
                src={pillar.thumb}
                alt={pillar.thumbAlt}
                width="760"
                height="440"
                loading="lazy"
                class="w-full rounded-lg border border-line bg-white shadow-sm transition-shadow duration-300 hover:shadow-md"
              />
              <div>
                <h3 class="font-display text-2xl font-bold tracking-tight">
                  {pillar.title}
                </h3>
                <p class="mt-3 font-mono text-xs leading-relaxed text-muted">
                  {pillar.chips.join(" · ")}
                </p>
                <p class="mt-5 font-mono text-xs font-medium tracking-wider text-pine-deep uppercase">
                  {pillar.clients}
                </p>
                {pillar.cases.map((text) => (
                  <p class="mt-3 text-muted">{text}</p>
                ))}
                {pillar.links.length > 0 && (
                  <ul class="mt-4 flex flex-wrap gap-x-6 gap-y-2">
                    {pillar.links.map((link) => (
                      <li>
                        <a
                          href={link.href}
                          target={link.external ? "_blank" : undefined}
                          rel={link.external ? "noopener noreferrer" : undefined}
                          class="text-sm font-medium text-pine hover:text-pine-deep"
                        >
                          {link.label}<span
                            class="text-indigo"
                            aria-hidden="true">&nbsp;↗</span
                          >
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 4. Try what we build -->
  <section id="demos" class="scroll-mt-24 border-y border-line bg-mist">
    <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6 md:py-28">
      <p class="font-mono text-xs font-medium tracking-widest text-pine-deep uppercase">
        Demos
      </p>
      <h2 class="mt-3 font-display text-4xl font-bold tracking-tight sm:text-5xl">
        Try what we build
      </h2>
      <div class="mt-12 grid gap-8 md:grid-cols-2">
        {
          demos.map((demo, i) => (
            <article
              class="reveal flex flex-col overflow-hidden rounded-lg border border-line bg-paper shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-lg"
              style={`transition-delay: ${i * 130}ms`}
            >
              <img
                src={demo.image}
                alt={demo.alt}
                width="800"
                height="450"
                loading="lazy"
                class="aspect-video w-full border-b border-line object-cover"
              />
              <div class="flex flex-1 flex-col p-6">
                <h3 class="font-display text-xl font-bold tracking-tight">
                  {demo.name}
                </h3>
                <p class="mt-2 flex-1 text-muted">{demo.description}</p>
                <a
                  href={demo.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group mt-5 inline-block self-start rounded-md border border-pine px-5 py-2.5 font-medium text-pine transition-colors hover:bg-pine hover:text-white"
                >
                  Launch demo<span
                    class="text-indigo transition-colors group-hover:text-white"
                    aria-hidden="true">&nbsp;↗</span
                  >
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 5. Working with W74 -->
  <section id="how-we-work" class="scroll-mt-24 border-b border-line">
    <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6 md:py-28">
      <p class="font-mono text-xs font-medium tracking-widest text-pine-deep uppercase">
        How we work
      </p>
      <h2 class="mt-3 font-display text-4xl font-bold tracking-tight sm:text-5xl">
        Working with W74
      </h2>
      <p class="mt-6 max-w-3xl text-lg text-muted">
        We partner with companies to build better products, accelerate growth,
        validate performance, and reduce OpEx. Typically we work embedded
        within your team or on project-specific engagements — tailored to your
        needs, across the focus areas above.
      </p>
      <p class="mt-8 font-mono text-xs font-medium tracking-wider text-pine-deep uppercase">
        Experience from pre-seed to Fortune 100
      </p>
      <p class="mt-3 font-mono text-xs tracking-wider text-muted uppercase">
        Google · Meta · Pfizer · Shell · Accenture · C3 AI · BlocPower ·
        Carbon Lighthouse · Jane Energy · Bedrock Energy
      </p>
      <figure
        class="reveal mt-14 grid items-center gap-6 border-t border-line pt-10 md:grid-cols-[auto_1fr] md:gap-10"
      >
        <img
          src="/assets/elaine-wang.webp"
          alt="Headshot of Elaine Wang"
          width="469"
          height="469"
          loading="lazy"
          class="h-24 w-24 shrink-0 rounded-full border border-line object-cover md:h-28 md:w-28"
        />
        <div>
          <blockquote class="max-w-3xl text-lg leading-relaxed text-ink">
            &ldquo;Partnering with Bradley and W74 was a game-changer for us.
            Their expertise in building science, climate, and product strategy
            helped us craft a clear, impactful pitch, enabling us to better
            communicate our vision as an early-stage startup. Their support has
            been invaluable on our journey so far.&rdquo;
          </blockquote>
          <figcaption class="mt-4 text-muted">
            Elaine Wang — CTO,{" "}
            <a
              href="https://jane.energy"
              target="_blank"
              rel="noopener noreferrer"
              class="font-medium text-pine hover:text-pine-deep"
            >
              Jane Energy<span class="text-indigo" aria-hidden="true"
                >&nbsp;↗</span
              >
            </a>
          </figcaption>
        </div>
      </figure>
    </div>
  </section>

  <!-- 6. Team -->
  <section id="team" class="scroll-mt-24">
    <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6 md:py-28">
      <p class="font-mono text-xs font-medium tracking-widest text-pine-deep uppercase">
        Team
      </p>
      <h2 class="mt-3 font-display text-4xl font-bold tracking-tight sm:text-5xl">
        W74 Team
      </h2>
      <ul class="mt-14 grid gap-x-12 gap-y-14 md:grid-cols-2">
        {
          team.map((member) => (
            <li class="reveal border-t border-line pt-8">
              <div class="flex items-center gap-5">
                <img
                  src={member.photo}
                  alt={`Headshot of ${member.name}`}
                  width="160"
                  height="160"
                  loading="lazy"
                  class="h-20 w-20 shrink-0 rounded-full border border-line object-cover"
                />
                <div>
                  <h3 class="font-display text-xl font-bold tracking-tight">
                    {member.name}
                  </h3>
                  <p class="mt-1 text-muted">{member.role}</p>
                  <a
                    href={member.linkedin}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="mt-1 inline-block text-sm font-medium text-pine hover:text-pine-deep"
                  >
                    LinkedIn<span class="text-indigo" aria-hidden="true"
                      >&nbsp;↗</span
                    >
                  </a>
                </div>
              </div>
              <p class="mt-6 text-muted">{member.bio}</p>
              {member.schools && (
                <div class="mt-5 flex flex-wrap items-center gap-x-6 gap-y-3">
                  {member.schools.map((school) => (
                    <img
                      src={school.logo}
                      alt={school.name}
                      title={school.name}
                      height="20"
                      loading="lazy"
                      class="h-5 w-auto opacity-60 grayscale transition duration-300 hover:opacity-100 hover:grayscale-0"
                    />
                  ))}
                </div>
              )}
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  {/* Closing CTA now lives in the dark footer (Base.astro) */}
</Base>
