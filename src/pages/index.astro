---
import Base from "../layouts/Base.astro";
import LoadCurve from "../components/LoadCurve.astro";
import { pillars } from "../data/pillars";
import { team } from "../data/team";

/* Stat colors match the W74 overview doc's metrics bar */
const stats = [
  { value: "$17M+", label: "Energy savings delivered", color: "text-pine" },
  { value: "200+", label: "Properties analyzed & monitored", color: "text-ink" },
  { value: "$8M+", label: "Revenue growth driven", color: "text-amber" },
  { value: "$150M+", label: "Venture financing supported", color: "text-indigo" },
];

const demos = [
  {
    name: "Energy Forecast App",
    description: "Interactive demo of W74's ML load forecasting.",
    url: "https://w74-forecast.streamlit.app/",
    image: "/assets/demo-forecast.webp",
    alt: "The W74 Energy Forecast App showing a quarterly forward forecast with predicted consumption, estimated spend, and emissions",
  },
  {
    name: "M&V App",
    description: "Interactive demo of W74's measurement & verification workflow.",
    url: "https://w74-energy.streamlit.app/",
    image: "/assets/demo-mv.webp",
    alt: "The W74 M&V App showing IPMVP Option C retrofit impact: annualized savings, energy reduction, and predicted-vs-actual consumption",
  },
];
---

<Base
  title="W74 — Product & Technology for Climate and Energy Companies"
  description="W74 partners with climate and energy companies to validate performance, reduce energy and OpEx, build better products, and accelerate growth — through fixed-scope projects or embedded fractional support."
>
  <!-- 1. Hero (load-curve band sits below the text in flow — no overlap) -->
  <section class="border-b border-line">
    <div class="mx-auto max-w-6xl px-4 pt-24 pb-16 sm:px-6 md:pt-32 md:pb-0">
      <h1
        class="max-w-3xl font-display text-4xl font-bold tracking-tight sm:text-6xl"
      >
        Accelerate your climate work
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-muted">
        W74 partners with climate &amp; energy companies to validate
        performance, reduce energy and OpEx, build better products, and
        accelerate growth — as fixed-scope projects or embedded fractional
        support.
      </p>
      <div class="mt-10 flex flex-wrap items-center gap-4">
        <a
          href="/request"
          class="rounded-md bg-pine px-6 py-3 font-medium text-white transition-colors hover:bg-pine-deep"
        >
          Book an intro call
        </a>
        <a href="#work" class="font-medium text-pine hover:text-pine-deep">
          See our work →
        </a>
      </div>
    </div>
    <LoadCurve
      class="pointer-events-none mx-auto hidden w-full max-w-[1600px] opacity-70 md:-mt-12 md:block"
    />
  </section>

  <!-- 2. Metrics bar -->
  <section aria-label="Results" class="border-b border-line bg-mist">
    <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
      <dl class="grid grid-cols-2 gap-x-6 gap-y-10 md:grid-cols-4">
        {
          stats.map((stat) => (
            <div class="flex flex-col-reverse">
              <dt class="mt-2 font-mono text-xs tracking-wider text-muted uppercase">
                {stat.label}
              </dt>
              <dd
                class:list={[
                  "font-display text-4xl font-bold tracking-tight sm:text-5xl",
                  stat.color,
                ]}
              >
                {stat.value}
              </dd>
            </div>
          ))
        }
      </dl>
      <p class="mt-8 font-mono text-xs text-muted">
        Cumulative figures across W74 client engagements and W74 team-led work.
      </p>
    </div>
  </section>

  <!-- 3. What we do — four pillars with case studies (W74-overview format) -->
  <section id="work" class="scroll-mt-24">
    <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6 md:py-28">
      <p class="font-mono text-xs tracking-widest text-muted uppercase">
        What we do
      </p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight sm:text-4xl">
        W74 Focus Areas
      </h2>
      <div class="mt-14 space-y-16">
        {
          pillars.map((pillar) => (
            <article
              id={pillar.id}
              class="grid scroll-mt-24 items-start gap-8 border-t border-line pt-10 md:grid-cols-[2fr_3fr] md:gap-12"
            >
              <img
                src={pillar.thumb}
                alt={pillar.thumbAlt}
                width="760"
                height="440"
                loading="lazy"
                class="w-full rounded-lg border border-line bg-white"
              />
              <div>
                <p class="font-mono text-sm text-indigo">{pillar.number}</p>
                <h3 class="mt-2 font-display text-2xl font-bold tracking-tight">
                  {pillar.title}
                </h3>
                <p class="mt-3 font-mono text-xs leading-relaxed text-muted">
                  {pillar.chips.join(" · ")}
                </p>
                <p class="mt-5 font-mono text-xs font-medium tracking-wider text-pine uppercase">
                  {pillar.clients}
                </p>
                {pillar.cases.map((text) => (
                  <p class="mt-3 text-muted">{text}</p>
                ))}
                {pillar.links.length > 0 && (
                  <ul class="mt-4 flex flex-wrap gap-x-6 gap-y-2">
                    {pillar.links.map((link) => (
                      <li>
                        <a
                          href={link.href}
                          target={link.external ? "_blank" : undefined}
                          rel={link.external ? "noopener noreferrer" : undefined}
                          class="text-sm font-medium text-pine hover:text-pine-deep"
                        >
                          {link.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </article>
          ))
        }
      </div>
      <div class="mt-14 border-t border-line pt-6">
        <p class="font-mono text-xs text-muted">
          † Work led by W74 team members at Accenture, prior to W74.
        </p>
        <p class="mt-2 font-mono text-xs text-muted">
          References &amp; introductions available on request.
        </p>
      </div>
    </div>
  </section>

  <!-- 4. Try what we build -->
  <section class="border-y border-line bg-mist">
    <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6 md:py-28">
      <h2 class="font-display text-3xl font-bold tracking-tight sm:text-4xl">
        Try what we build
      </h2>
      <p class="mt-3 text-lg text-muted">Working demos, not slideware.</p>
      <div class="mt-12 grid gap-8 md:grid-cols-2">
        {
          demos.map((demo) => (
            <article class="flex flex-col overflow-hidden rounded-lg border border-line bg-paper">
              <img
                src={demo.image}
                alt={demo.alt}
                width="800"
                height="450"
                loading="lazy"
                class="aspect-video w-full border-b border-line object-cover"
              />
              <div class="flex flex-1 flex-col p-6">
                <h3 class="font-display text-xl font-bold tracking-tight">
                  {demo.name}
                </h3>
                <p class="mt-2 flex-1 text-muted">{demo.description}</p>
                <a
                  href={demo.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-5 inline-block self-start rounded-md border border-pine px-5 py-2.5 font-medium text-pine transition-colors hover:bg-pine hover:text-white"
                >
                  Launch demo →
                </a>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  {/* "How we work" section removed 2026-07-10 — Bradley is rewriting it; restore from git history when new copy lands */}

  <!-- 5. Team -->
  <section id="team" class="scroll-mt-24">
    <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6 md:py-28">
      <p class="font-mono text-xs tracking-widest text-muted uppercase">Team</p>
      <h2 class="mt-3 font-display text-3xl font-bold tracking-tight sm:text-4xl">
        W74 Team
      </h2>
      <ul class="mt-14 grid gap-x-12 gap-y-14 md:grid-cols-2">
        {
          team.map((member) => (
            <li class="border-t border-line pt-8">
              <div class="flex items-center gap-5">
                <img
                  src={member.photo}
                  alt={`Headshot of ${member.name}`}
                  width="160"
                  height="160"
                  loading="lazy"
                  class="h-20 w-20 shrink-0 rounded-full border border-line object-cover"
                />
                <div>
                  <h3 class="font-display text-xl font-bold tracking-tight">
                    {member.name}
                  </h3>
                  <p class="mt-1 text-muted">{member.role}</p>
                  <a
                    href={member.linkedin}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="mt-1 inline-block text-sm font-medium text-pine hover:text-pine-deep"
                  >
                    LinkedIn →
                  </a>
                </div>
              </div>
              <p class="mt-6 text-muted">{member.bio}</p>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <!-- 6. Closing CTA band -->
  <section class="border-t border-line bg-ink">
    <div
      class="mx-auto flex max-w-6xl flex-col items-start gap-6 px-4 py-16 sm:px-6 md:flex-row md:items-center md:justify-between"
    >
      <h2 class="font-display text-3xl font-bold tracking-tight text-white">
        Ready to get started?
      </h2>
      <div class="flex flex-wrap items-center gap-6">
        <a
          href="/request"
          class="rounded-md bg-pine px-6 py-3 font-medium text-white transition-colors hover:bg-pine-deep"
        >
          Book an intro call
        </a>
        <a href="mailto:info@w74.io" class="text-lg text-mist hover:text-white">
          info@w74.io
        </a>
      </div>
    </div>
  </section>
</Base>
