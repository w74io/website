---
import Base from "../layouts/Base.astro";
---

<Base
  title="Page not found — W74"
  description="That page doesn't exist."
  noindex
>
  <div class="mx-auto max-w-3xl px-4 py-24 sm:px-6 md:py-36">
    <p class="font-mono text-xs font-medium tracking-widest text-pine-deep uppercase">
      404
    </p>
    <h1 class="mt-3 font-display text-4xl font-bold tracking-tight sm:text-5xl">
      Nothing here
    </h1>
    <p class="mt-6 text-lg text-muted">
      That page doesn't exist — but the work does.
    </p>
    <div class="mt-10 flex flex-wrap items-center gap-4">
      <a
        href="/"
        class="rounded-md bg-pine px-6 py-3 font-medium text-white shadow-sm transition-all hover:-translate-y-0.5 hover:bg-pine-deep hover:shadow-md"
      >
        Back to home
      </a>
      <a href="/#work" class="font-medium text-pine hover:text-pine-deep">
        See our work
      </a>
    </div>
  </div>
</Base>
