---
/**
 * Signature element: an IPMVP-style M&V chart — dashed weather-normalized
 * baseline vs. solid actual metered load, diverging after the measure is
 * implemented; the shaded gap is the savings. Rendered as a flat band between
 * the hero text and CTA row (never behind text). Decorative only (aria-hidden).
 */
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<svg
  viewBox="0 0 960 190"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  class={className}
  preserveAspectRatio="xMidYMid meet"
>
  <!-- month gridlines -->
  {
    Array.from({ length: 11 }, (_, i) => (
      <line
        x1={(i + 1) * 80}
        y1="14"
        x2={(i + 1) * 80}
        y2="170"
        stroke="var(--color-line)"
        stroke-width="1"
      />
    ))
  }

  <!-- savings gap: area between baseline and actual after the measure -->
  <path
    d="M600,73 C660,93 720,115 780,123 C840,131 900,143 960,147 L960,67 C900,63 840,77 780,70 C720,60 660,77 600,73 Z"
    fill="var(--color-pine)"
    fill-opacity="0.09"
  />

  <!-- weather-normalized baseline (dashed) -->
  <path
    d="M0,80 C80,65 160,95 240,77 C320,60 400,90 480,75 C540,67 570,70 600,73 C660,77 720,60 780,70 C840,77 900,63 960,67"
    stroke="var(--color-muted)"
    stroke-width="1.5"
    stroke-dasharray="6 6"
    stroke-opacity="0.55"
  />

  <!-- actual metered load (solid, pine) -->
  <path
    d="M0,80 C80,65 160,95 240,77 C320,60 400,90 480,75 C540,67 570,70 600,73 C660,93 720,115 780,123 C840,131 900,143 960,147"
    stroke="var(--color-pine)"
    stroke-width="2"
  />

  <!-- measure-implemented marker -->
  <line
    x1="600"
    y1="18"
    x2="600"
    y2="170"
    stroke="var(--color-muted)"
    stroke-width="1"
    stroke-dasharray="2 4"
    stroke-opacity="0.5"
  />
  <circle cx="600" cy="73" r="3.5" fill="var(--color-pine)"></circle>

  <!-- chart annotations -->
  <text
    x="610"
    y="13"
    font-family="var(--font-mono)"
    font-size="11"
    fill="var(--color-muted)"
    letter-spacing="0.04em"
  >
    MEASURE IMPLEMENTED
  </text>
  <text
    x="640"
    y="47"
    font-family="var(--font-mono)"
    font-size="11"
    fill="var(--color-muted)"
    letter-spacing="0.04em"
  >
    WEATHER-NORMALIZED BASELINE
  </text>
  <text
    x="700"
    y="168"
    font-family="var(--font-mono)"
    font-size="11"
    fill="var(--color-pine)"
    letter-spacing="0.04em"
  >
    ACTUAL
  </text>
</svg>
