---
/**
 * Signature element: an IPMVP-style M&V chart — dashed weather-normalized
 * baseline vs. solid actual metered load, diverging after the measure is
 * implemented; the shaded gap is the savings. Rendered as a flat band below
 * the hero text (never behind it). Decorative only (aria-hidden).
 */
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<svg
  viewBox="0 0 960 220"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  class={className}
  preserveAspectRatio="xMidYMid meet"
>
  <!-- month gridlines -->
  {
    Array.from({ length: 11 }, (_, i) => (
      <line
        x1={(i + 1) * 80}
        y1="30"
        x2={(i + 1) * 80}
        y2="195"
        stroke="var(--color-line)"
        stroke-width="1"
      />
    ))
  }

  <!-- savings gap: area between baseline and actual after the measure -->
  <path
    d="M600,88 C660,108 720,130 780,138 C840,146 900,158 960,162 L960,82 C900,78 840,92 780,85 C720,75 660,92 600,88 Z"
    fill="var(--color-pine)"
    fill-opacity="0.09"
  />

  <!-- weather-normalized baseline (dashed) -->
  <path
    d="M0,95 C80,80 160,110 240,92 C320,75 400,105 480,90 C540,82 570,85 600,88 C660,92 720,75 780,85 C840,92 900,78 960,82"
    stroke="var(--color-muted)"
    stroke-width="1.5"
    stroke-dasharray="6 6"
    stroke-opacity="0.55"
  />

  <!-- actual metered load (solid, pine) -->
  <path
    d="M0,95 C80,80 160,110 240,92 C320,75 400,105 480,90 C540,82 570,85 600,88 C660,108 720,130 780,138 C840,146 900,158 960,162"
    stroke="var(--color-pine)"
    stroke-width="2"
  />

  <!-- measure-implemented marker -->
  <line
    x1="600"
    y1="34"
    x2="600"
    y2="195"
    stroke="var(--color-muted)"
    stroke-width="1"
    stroke-dasharray="2 4"
    stroke-opacity="0.5"
  />
  <circle cx="600" cy="88" r="3.5" fill="var(--color-pine)"></circle>

  <!-- chart annotations -->
  <text
    x="610"
    y="28"
    font-family="var(--font-mono)"
    font-size="11"
    fill="var(--color-muted)"
    letter-spacing="0.04em"
  >
    MEASURE IMPLEMENTED
  </text>
  <text
    x="640"
    y="62"
    font-family="var(--font-mono)"
    font-size="11"
    fill="var(--color-muted)"
    letter-spacing="0.04em"
  >
    WEATHER-NORMALIZED BASELINE
  </text>
  <text
    x="700"
    y="185"
    font-family="var(--font-mono)"
    font-size="11"
    fill="var(--color-pine)"
    letter-spacing="0.04em"
  >
    ACTUAL
  </text>
</svg>
