---
/**
 * Signature element: an IPMVP-style M&V chart — dashed weather-normalized
 * baseline vs. solid actual metered load, diverging after the measure is
 * implemented; the shaded gap is the savings. Decorative only (aria-hidden).
 */
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<svg
  viewBox="0 0 960 300"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
  class={className}
  preserveAspectRatio="xMidYMid meet"
>
  <!-- month gridlines -->
  {
    Array.from({ length: 11 }, (_, i) => (
      <line
        x1={(i + 1) * 80}
        y1="40"
        x2={(i + 1) * 80}
        y2="270"
        stroke="var(--color-line)"
        stroke-width="1"
      />
    ))
  }

  <!-- savings gap: area between baseline and actual after the measure -->
  <path
    d="M600,138 C660,165 720,195 780,205 C840,215 900,235 960,238 L960,132 C900,125 840,148 780,135 C720,120 660,145 600,138 Z"
    fill="var(--color-pine)"
    fill-opacity="0.09"
  />

  <!-- weather-normalized baseline (dashed) -->
  <path
    d="M0,150 C80,130 160,170 240,145 C320,120 400,160 480,140 C540,128 570,132 600,138 C660,145 720,120 780,135 C840,148 900,125 960,132"
    stroke="var(--color-muted)"
    stroke-width="1.5"
    stroke-dasharray="6 6"
    stroke-opacity="0.55"
  />

  <!-- actual metered load (solid, pine) -->
  <path
    d="M0,150 C80,130 160,170 240,145 C320,120 400,160 480,140 C540,128 570,132 600,138 C660,165 720,195 780,205 C840,215 900,235 960,238"
    stroke="var(--color-pine)"
    stroke-width="2"
  />

  <!-- measure-implemented marker -->
  <line
    x1="600"
    y1="52"
    x2="600"
    y2="268"
    stroke="var(--color-muted)"
    stroke-width="1"
    stroke-dasharray="2 4"
    stroke-opacity="0.5"
  />
  <circle cx="600" cy="138" r="3.5" fill="var(--color-pine)"></circle>

  <!-- chart annotations -->
  <text
    x="610"
    y="46"
    font-family="var(--font-mono)"
    font-size="11"
    fill="var(--color-muted)"
    letter-spacing="0.04em"
  >
    MEASURE IMPLEMENTED
  </text>
  <text
    x="640"
    y="112"
    font-family="var(--font-mono)"
    font-size="11"
    fill="var(--color-muted)"
    letter-spacing="0.04em"
  >
    WEATHER-NORMALIZED BASELINE
  </text>
  <text
    x="700"
    y="262"
    font-family="var(--font-mono)"
    font-size="11"
    fill="var(--color-pine)"
    letter-spacing="0.04em"
  >
    ACTUAL
  </text>
</svg>
