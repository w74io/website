---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  /** Set false on utility pages (e.g. form success) to keep them out of search. */
  noindex?: boolean;
}

const { title, description, noindex = false } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);

const navLinks = [
  { href: "/#work", label: "Projects" },
  { href: "/#team", label: "Team" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="preload"
      href="/fonts/space-grotesk-var.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="W74" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL("/assets/og.png", Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      // Reveal-on-scroll: .js gates the hidden state so no-JS visitors see everything.
      document.documentElement.classList.add("js");
      window.addEventListener("DOMContentLoaded", () => {
        const els = document.querySelectorAll(".reveal");
        if (
          !("IntersectionObserver" in window) ||
          matchMedia("(prefers-reduced-motion: reduce)").matches
        ) {
          els.forEach((el) => el.classList.add("is-visible"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -40px 0px" }
        );
        els.forEach((el) => io.observe(el));
      });
    </script>
  </head>
  <body class="flex min-h-screen flex-col">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:bg-paper focus:px-4 focus:py-2 focus:text-ink"
    >
      Skip to content
    </a>

    <header class="border-b border-line">
      <nav
        aria-label="Main"
        class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-4 sm:px-6"
      >
        <a href="/" class="flex items-center gap-3" aria-label="W74 home">
          <img
            src="/assets/W74_Logo_Kit_v02/svg/w74_mark_dark_green74.svg"
            alt=""
            width="36"
            height="36"
            class="h-9 w-9"
          />
          <span class="hidden flex-col leading-tight sm:flex">
            <span class="text-sm font-medium text-ink">
              Product &amp; Technology
            </span>
            <span class="font-mono text-xs text-muted">
              Energy · Climate · AI
            </span>
          </span>
        </a>
        <div class="flex items-center gap-4 sm:gap-8">
          {
            navLinks.map((link) => (
              <a href={link.href} class="text-sm text-muted hover:text-ink">
                {link.label}
              </a>
            ))
          }
          <a
            href="/request"
            class="rounded-md bg-pine px-3 py-2 text-sm font-medium text-white shadow-sm transition-all hover:-translate-y-0.5 hover:bg-pine-deep hover:shadow-md sm:px-4"
          >
            Book an intro call
          </a>
        </div>
      </nav>
    </header>

    <main id="main" class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-line">
      <div
        class="mx-auto flex max-w-6xl flex-col gap-4 px-4 py-10 text-sm text-muted sm:px-6 md:flex-row md:items-center md:justify-between"
      >
        <div class="flex flex-col gap-2 sm:flex-row sm:flex-wrap sm:items-center sm:gap-x-3">
          <span>W74 Ventures LLC</span>
          <span aria-hidden="true" class="hidden sm:inline">·</span>
          <a href="mailto:info@w74.io" class="hover:text-ink">info@w74.io</a>
          <span aria-hidden="true" class="hidden sm:inline">·</span>
          <a
            href="https://www.linkedin.com/company/w74-advisors/"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-ink"
          >
            LinkedIn
          </a>
          <span aria-hidden="true" class="hidden sm:inline">·</span>
          <a href="/assets/w74-overview.pdf" class="hover:text-ink">
            Download the W74 overview (PDF)
          </a>
        </div>
        <p>© 2026 W74 Ventures, LLC.</p>
      </div>
    </footer>
  </body>
</html>
